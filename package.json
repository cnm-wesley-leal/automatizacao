{
  "name": "automatizacao",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@playwright/mcp": "^0.0.73",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:with-testdino": "playwright test && npx ts-node scripts/send-to-testdino.ts",
    "testdino:report": "npx ts-node scripts/send-to-testdino.ts",
    "testdino:sync": "playwright test --reporter=json > playwright-results.json; npx ts-node scripts/send-to-testdino.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
